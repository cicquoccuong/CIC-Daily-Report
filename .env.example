# === REQUIRED (6) ===
GOOGLE_SHEETS_CREDENTIALS=     # Base64-encoded Service Account JSON
GOOGLE_SHEETS_SPREADSHEET_ID=  # Spreadsheet ID from URL
TELEGRAM_BOT_TOKEN=            # Bot token from @BotFather
TELEGRAM_CHAT_ID=              # Chat ID for delivery (operator's chat)
GROQ_API_KEY=                  # Groq API key (primary LLM)
CRYPTOPANIC_API_KEY=           # CryptoPanic API key (news + sentiment)

# === OPTIONAL (9) ===
GEMINI_API_KEY=                # Google Gemini API key (LLM fallback #1)
# GEMINI_FLASH_LITE_API_KEY uses same key as GEMINI_API_KEY (different model)
FRED_API_KEY=                  # FRED API key (macro data: DGS10, CPI)
TELEGRAM_API_ID=               # Telegram user API ID (channel scraping)
TELEGRAM_API_HASH=             # Telegram user API hash (channel scraping)
TELEGRAM_SESSION_STRING=       # Telegram user session (channel scraping)
GLASSNODE_API_KEY=             # Glassnode API key (on-chain data)
COINGLASS_API_KEY=             # Coinglass API key (derivatives data)
SMTP_HOST=                     # SMTP server for email backup (e.g., smtp.gmail.com)
SMTP_USER=                     # SMTP username
SMTP_PASSWORD=                 # SMTP password / app password
